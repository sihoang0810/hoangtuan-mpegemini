    "@sanity/react-loader": "^2.0.10",
    "@sanity/ui": "^3.2.0",
    "@sanity/vision": "^5.26.0",
    "@sanity/visual-editing": "^5.3.6",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
